rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: uid
    // Fields: uid, email, displayName, photoURL, role, companyId, createdAt
    //
    // Collection: projects
    // Document ID: projectId
    // Fields: id, name, customerId, status, description, address, assignedTo, createdAt, updatedAt
    //
    // Collection: projects/{projectId}/surveys
    // Document ID: surveyId
    // Fields: id, projectId, title, type, mediaUrl, canvasData, notes, createdBy, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' ||
        (request.auth.token.email == "info@dakiktabela.com" && request.auth.token.email_verified == true)
      );
    }

    function isDesigner() {
      return isAuthenticated() && getUserData().role == 'designer';
    }

    function isSurveyor() {
      return isAuthenticated() && getUserData().role == 'surveyor';
    }

    function isAssignedToProject(projectId) {
      return isAuthenticated() && (
        isAdmin() || 
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.assignedTo
      );
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role in ['admin', 'designer', 'surveyor', 'production', 'installer'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.status in ['draft', 'pending_survey', 'surveying', 'survey_completed', 'design_in_progress', 'revision', 'pending_approval', 'in_production', 'in_installation', 'completed'];
    }

    function isValidSurvey(data) {
      return data.keys().hasAll(['projectId', 'title', 'type']) &&
             data.projectId is string && data.title is string &&
             data.type in ['facade', 'interior', 'exterior', 'vehicle', 'custom'];
    }

    // Rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isDesigner();
      allow update: if isAdmin() || isDesigner() || isSurveyor();
      allow delete: if isAdmin();

      match /surveys/{surveyId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin() || isDesigner() || isSurveyor();
        allow update: if isAdmin() || isDesigner() || isSurveyor();
        allow delete: if isAdmin();
      }
    }
  }
}
